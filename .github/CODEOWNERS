# Engineering owns everything by default: CI/workflows, scripts, shared
# components/layouts/config, and anything else outside the top-level email
# templates.
* @datum-cloud/engineering

# The top-level email templates (content/copy) are GTM's domain — this is
# what the content-change-request and new-template-request issue flows (and
# their AI-assisted draft PRs) edit. Doesn't cover emails/components/,
# emails/layouts/, or emails/config/, which stay engineering's above.
/emails/*.tsx @datum-cloud/gtm

# Auto-generated from the templates above (config/email-templates/ by
# verify-bundle.yml's auto-commit, screenshots/ by screenshot-templates.yml) —
# same owner as the source they're derived from, not hand-edited by anyone.
/config/email-templates/ @datum-cloud/gtm
/screenshots/ @datum-cloud/gtm
